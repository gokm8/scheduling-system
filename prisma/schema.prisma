generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id     String  @id @default(uuid())
  name   String
  email  String  @unique
  role   Role
  shifts Shift[]
}

model Shift {
  id         String    @id @default(uuid())
  startsAt   DateTime
  endsAt     DateTime
  role       Role
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

enum Role {
  KØKKENCHEF
  SOUSCHEF
  KOK
  KØKKENASSISTENT
  TJENER
  OPVASKER
}
